rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Connection Test
    match /test/connection {
      allow read: if true;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null && request.auth.token.email != null;
    }
    
    function getMemberData() {
      return get(/databases/$(database)/documents/team_members/$(request.auth.token.email)).data;
    }
    
    function isMemberOf(tenantId) {
      return isSignedIn() && (
        request.auth.uid == tenantId ||
        (exists(/databases/$(database)/documents/team_members/$(request.auth.token.email)) && 
         get(/databases/$(database)/documents/team_members/$(request.auth.token.email)).data.tenantId == tenantId)
      );
    }
    
    function isOwnerOf(tenantId) {
      return isSignedIn() && (
        request.auth.uid == tenantId ||
        (exists(/databases/$(database)/documents/team_members/$(request.auth.token.email)) && 
         get(/databases/$(database)/documents/team_members/$(request.auth.token.email)).data.tenantId == tenantId &&
         get(/databases/$(database)/documents/team_members/$(request.auth.token.email)).data.role == 'owner')
      );
    }

    function isManagerOf(tenantId) {
      return isSignedIn() && (
        isOwnerOf(tenantId) ||
        (exists(/databases/$(database)/documents/team_members/$(request.auth.token.email)) && 
         get(/databases/$(database)/documents/team_members/$(request.auth.token.email)).data.tenantId == tenantId &&
         get(/databases/$(database)/documents/team_members/$(request.auth.token.email)).data.role == 'manager')
      );
    }

    function isCantinaOf(tenantId) {
       return isSignedIn() && (
         isManagerOf(tenantId) ||
         (exists(/databases/$(database)/documents/team_members/$(request.auth.token.email)) && 
          get(/databases/$(database)/documents/team_members/$(request.auth.token.email)).data.tenantId == tenantId &&
          get(/databases/$(database)/documents/team_members/$(request.auth.token.email)).data.role == 'cantina')
       );
    }

    function isRootOwnerOf(tenantId) {
      return isSignedIn() && request.auth.uid == tenantId;
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidString(val, max) {
      return val is string && val.size() <= max;
    }

    // --- team_members ---
    match /team_members/{email} {
      allow get: if isSignedIn() && (request.auth.token.email == email || isOwnerOf(resource.data.tenantId));
      allow list: if isSignedIn() && isCantinaOf(resource.data.tenantId);

      allow create: if isSignedIn() && (
        // Self-registration as owner (happens on first login)
        (request.auth.token.email == email && incoming().role == 'owner' && incoming().tenantId == request.auth.uid) ||
        // Staff inviting someone (only non-owners)
        (isCantinaOf(incoming().tenantId) && (incoming().role in ['viewer', 'manager', 'cantina'])) ||
        // Owners can invite anyone
        (isOwnerOf(incoming().tenantId) && (incoming().role in ['viewer', 'owner', 'manager', 'cantina']))
      ) && incoming().email == email;

      allow delete: if isSignedIn() && (
        // Root owner can delete any record except their personal record
        (isRootOwnerOf(resource.data.tenantId) && request.auth.token.email != email) ||
        // Other staff can delete non-owners/non-managers if they have higher/equal role?
        // Let's simplify: Owners can delete anyone except other owners. 
        // Managers/Cantina can delete viewers.
        (isOwnerOf(resource.data.tenantId) && resource.data.role != 'owner') ||
        (isCantinaOf(resource.data.tenantId) && resource.data.role == 'viewer')
      );

      allow update: if isSignedIn() && isCantinaOf(resource.data.tenantId) && (incoming().tenantId == resource.data.tenantId);
    }

    // --- accounts ---
    match /accounts/{id} {
      allow read: if isSignedIn() && isMemberOf(resource.data.tenantId);
      allow write: if isSignedIn() && isOwnerOf(resource.data.tenantId);
    }

    // --- transfers ---
    match /transfers/{id} {
      allow read: if isSignedIn() && isMemberOf(resource.data.tenantId);
      allow write: if isSignedIn() && isManagerOf(resource.data.tenantId);
    }

    // --- transactions ---
    match /transactions/{id} {
      allow read: if isSignedIn() && isMemberOf(resource.data.userId);
      
      allow create: if isSignedIn() && isCantinaOf(incoming().userId) && 
                    isValidString(incoming().description, 500) &&
                    incoming().amount is number;
                    
      allow update: if isSignedIn() && isCantinaOf(resource.data.userId) &&
                    incoming().userId == resource.data.userId;
                    
      allow delete: if isSignedIn() && isManagerOf(resource.data.userId);
    }

    // --- debts ---
    match /debts/{id} {
      allow read: if isSignedIn() && isMemberOf(resource.data.userId);
      allow create: if isSignedIn() && isManagerOf(incoming().userId);
      allow update: if isSignedIn() && isManagerOf(resource.data.userId) && (incoming().userId == resource.data.userId);
      allow delete: if isSignedIn() && isOwnerOf(resource.data.userId);
    }

    // --- bills ---
    match /bills/{id} {
      allow read: if isSignedIn() && isMemberOf(resource.data.userId);
      allow create: if isSignedIn() && isManagerOf(incoming().userId);
      allow update: if isSignedIn() && isManagerOf(resource.data.userId) && (incoming().userId == resource.data.userId);
      allow delete: if isSignedIn() && isOwnerOf(resource.data.userId);
    }
  }
}
