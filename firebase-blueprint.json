{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction representing Income, Expense, or Transfer.",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense", "transfer"] },
        "category": { "type": "string" },
        "accountId": { "type": "string" },
        "toAccountId": { "type": "string", "description": "Mandatory for transfers" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "createdAt": { "type": "integer" },
        "userId": { "type": "string" },
        "deleted": { "type": "boolean" }
      },
      "required": ["amount", "type", "category", "accountId", "description", "date", "createdAt", "userId"]
    },
    "Account": {
      "title": "Account",
      "description": "A financial account (bank, cash, etc.) with a balance.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "balance": { "type": "number" },
        "tenantId": { "type": "string" },
        "createdAt": { "type": "integer" },
        "color": { "type": "string" }
      },
      "required": ["name", "balance", "tenantId", "createdAt"]
    },
    "Transfer": {
      "title": "Transfer",
      "description": "A record of money moving between accounts.",
      "type": "object",
      "properties": {
        "fromAccountId": { "type": "string" },
        "toAccountId": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "description": { "type": "string" },
        "tenantId": { "type": "string" },
        "createdAt": { "type": "integer" }
      },
      "required": ["fromAccountId", "toAccountId", "amount", "date", "description", "tenantId", "createdAt"]
    },
    "Debt": {
      "title": "Debt",
      "description": "A liability like a credit card, loan, or other pending debt.",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "totalAmount": { "type": "number" },
        "paidAmount": { "type": "number" },
        "dueDate": { "type": "string", "format": "date" },
        "type": { "type": "string", "enum": ["card", "loan", "other"] },
        "status": { "type": "string", "enum": ["active", "paid"] },
        "installments": { "type": "number" },
        "remainingInstallments": { "type": "number" },
        "installmentValue": { "type": "number" },
        "userId": { "type": "string" },
        "createdAt": { "type": "integer" }
      },
      "required": ["description", "totalAmount", "paidAmount", "type", "status", "userId", "createdAt"]
    },
    "Bill": {
      "title": "Bill",
      "description": "An account payable (monthly bill, invoice, etc.) indexed by day.",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "dueDate": { "type": "string", "format": "date" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "paid"] },
        "userId": { "type": "string" },
        "createdAt": { "type": "integer" }
      },
      "required": ["description", "amount", "dueDate", "category", "status", "userId", "createdAt"]
    },
    "TeamMember": {
      "title": "TeamMember",
      "description": "An invited team member with specific access role.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["owner", "viewer"] },
        "tenantId": { "type": "string" },
        "invitedAt": { "type": "integer" }
      },
      "required": ["email", "role", "tenantId", "invitedAt"]
    }
  },
  "firestore": {
    "accounts": {
      "schema": "Account",
      "description": "Collection of all financial accounts."
    },
    "transactions": {
      "schema": "Transaction",
      "description": "Collection of all financial transactions."
    },
    "transfers": {
      "schema": "Transfer",
      "description": "Collection of all inter-account transfers."
    },
    "debts": {
      "schema": "Debt",
      "description": "Collection of financial liabilities."
    },
    "bills": {
      "schema": "Bill",
      "description": "Collection of scheduled bills to pay."
    },
    "team_members": {
      "schema": "TeamMember",
      "description": "Collection of invited team members."
    }
  }
}
